# MCP server credentials template for shared/mcp/*.json fragments.
# Copy to .env and fill in. .env is gitignored.

# Lab gateway HTTP bearer tokens
LAB_GW_UNRUST_AUTH_HEADER=
LAB_GW_RUSTIFY_AUTH_HEADER=
LAB_GW_RUSTIFI_AUTH_HEADER=
LAB_GW_RUSTSCALE_AUTH_HEADER=
LAB_GW_APPRISE_MCP_AUTH_HEADER=
LAB_GW_RMCP_TEMPLATE_AUTH_HEADER=
LAB_GW_SYSLOG_AUTH_HEADER=
LAB_GW_WINDOWS_MCP_AUTH_HEADER=

# windows-mcp-steamy (separate token from main windows-mcp)
WINDOWS_MCP_STEAMY_TOKEN=

# agentmemory (gemini-style local dev build)
AGENTMEMORY_URL=
AGENTMEMORY_SECRET=

# Android SDK path for claude-in-mobile
ANDROID_HOME=
